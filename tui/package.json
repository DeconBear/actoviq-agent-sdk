{
  "name": "actoviq-tui",
  "version": "0.1.0",
  "description": "Terminal UI agent powered by Actoviq Agent SDK",
  "type": "module",
  "license": "MIT",
  "bin": {
    "actoviq-fullscreen": "./bin/actoviq.cjs"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist",
    "bin"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/add-shebang.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "node --loader tsx src/cli.tsx",
    "test": "vitest run"
  },
  "dependencies": {
    "actoviq-agent-sdk": "file:..",
    "ink": "^6.0.0",
    "ink-text-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "react": "^19.1.0",
    "chalk": "^5.4.1"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "typescript": "^5.8.3"
  }
}
