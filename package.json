{
  "name": "actoviq-agent-sdk",
  "version": "0.2.0",
  "description": "A clean, public agent SDK with Actoviq and MCP integrations.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DeconBear/actoviq-agent-sdk.git"
  },
  "homepage": "https://github.com/DeconBear/actoviq-agent-sdk#readme",
  "bugs": {
    "url": "https://github.com/DeconBear/actoviq-agent-sdk/issues"
  },
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "bin": {
    "actoviq-react": "./bin/actoviq-react.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "README-zh.md",
    "vendor/actoviq-runtime/cli.js",
    "vendor/actoviq-runtime/runtime.bundle.br"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "clean": "node scripts/clean-dist.mjs",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepack": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "npm run build && tsx scripts/integration-smoke.ts",
    "example:quickstart": "npm run build && tsx examples/quickstart.ts",
    "example:session": "npm run build && tsx examples/session.ts",
    "example:stream-loop": "npm run build && tsx examples/stream-loop.ts",
    "example:actoviq-file-tools": "npm run build && tsx examples/actoviq-file-tools.ts",
    "example:actoviq-agent-helpers": "npm run build && tsx examples/actoviq-agent-helpers.ts",
    "example:actoviq-platform": "npm run build && tsx examples/actoviq-platform.ts",
    "example:parallel": "npm run build && tsx examples/parallel.ts",
    "example:session-manager": "npm run build && tsx examples/session-manager.ts",
    "example:checkpoint": "npm run build && tsx examples/checkpoint.ts",
    "example:workflow": "npm run build && tsx examples/workflow.ts",
    "example:workflow-annotated": "npm run build && tsx examples/workflow-annotated.ts",
    "example:workflow-agent-orchestration": "npm run build && tsx examples/workflow-agent-orchestration.ts",
    "example:scheduling": "npm run build && tsx examples/scheduling.ts",
    "example:react-loop": "npm run build && tsx examples/react-loop.ts",
    "example:actoviq-buddy": "npm run build && tsx examples/actoviq-buddy.ts",
    "example:actoviq-bridge-sdk": "npm run build && tsx examples/actoviq-bridge-sdk.ts"
  },
  "keywords": [
    "agent",
    "sdk",
    "actoviq",
    "mcp",
    "runtime"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "bun": "^1.3.11",
    "glob": "^13.0.0",
    "lodash-es": "^4.17.23",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "vitepress": "^1.6.3",
    "vitest": "^4.0.8"
  }
}
