{
  "name": "actoviq-agent-sdk",
  "version": "0.1.8",
  "description": "A clean, public agent SDK with Actoviq and MCP integrations.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DeconBear/actoviq-agent-sdk.git"
  },
  "homepage": "https://github.com/DeconBear/actoviq-agent-sdk#readme",
  "bugs": {
    "url": "https://github.com/DeconBear/actoviq-agent-sdk/issues"
  },
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "README-zh.md",
    "vendor/actoviq-runtime/cli.js",
    "vendor/actoviq-runtime/runtime.bundle.br"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "clean": "node scripts/clean-dist.mjs",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare:public-runtime": "node scripts/prepare-public-runtime.mjs",
    "sync:actoviq-runtime": "node scripts/sync-actoviq-runtime-upstream.mjs",
    "smoke": "npm run build && tsx scripts/integration-smoke.ts",
    "example:actoviq-file-tools": "npm run build && tsx examples/actoviq-file-tools.ts",
    "example:actoviq-agent-helpers": "npm run build && tsx examples/actoviq-agent-helpers.ts",
    "example:actoviq-buddy": "npm run build && tsx examples/actoviq-buddy.ts",
    "example:actoviq-computer-use": "npm run build && tsx examples/actoviq-computer-use.ts",
    "example:actoviq-memory": "npm run build && tsx examples/actoviq-memory.ts",
    "example:actoviq-session-memory": "npm run build && tsx examples/actoviq-session-memory.ts",
    "example:actoviq-swarm": "npm run build && tsx examples/actoviq-swarm.ts",
    "example:actoviq-introspection": "npm run build && tsx examples/actoviq-introspection.ts",
    "example:actoviq-bridge-sdk": "npm run build && tsx examples/actoviq-bridge-sdk.ts",
    "example:actoviq-interactive-agent": "npm run build && tsx examples/actoviq-interactive-agent.ts",
    "example:actoviq-workspaces": "npm run build && tsx examples/actoviq-workspaces.ts",
    "example:quickstart": "npm run build && tsx examples/quickstart.ts",
    "example:actoviq-sessions": "npm run build && tsx examples/actoviq-sessions.ts",
    "example:actoviq-session-messages": "npm run build && tsx examples/actoviq-session-messages.ts",
    "example:session": "npm run build && tsx examples/session.ts",
    "example:stream-loop": "npm run build && tsx examples/stream-loop.ts"
  },
  "keywords": [
    "agent",
    "sdk",
    "actoviq",
    "mcp",
    "runtime"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "bun": "^1.3.11",
    "glob": "^13.0.0",
    "lodash-es": "^4.17.23",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "vitest": "^4.0.8"
  }
}
