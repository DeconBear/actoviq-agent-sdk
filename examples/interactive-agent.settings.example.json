{
  "bypassPermissions": true,
  "env": {
    "ACTOVIQ_BASE_URL": "https://your-actoviq-compatible-endpoint.example.com",
    "ACTOVIQ_AUTH_TOKEN": "replace-with-your-token",
    "ACTOVIQ_DEFAULT_OPUS_MODEL": "replace-with-your-opus-model",
    "ACTOVIQ_DEFAULT_SONNET_MODEL": "replace-with-your-sonnet-model",
    "ACTOVIQ_DEFAULT_HAIKU_MODEL": "replace-with-your-haiku-model"
  },
  "permissions": {
    "allow": [
      "Bash",
      "Write",
      "Read",
      "WebSearch",
      "WebFetch",
      "Edit",
      "Glop",
      "Grep",
      "LSP",
      "PowerShell"
    ]
  }
}
