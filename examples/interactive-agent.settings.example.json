{
  "bypassPermissions": true,
  "env": {
    "ACTOVIQ_BASE_URL": "https://your-actoviq-compatible-endpoint.example.com",
    "ACTOVIQ_AUTH_TOKEN": "replace-with-your-token",
    "ACTOVIQ_DEFAULT_MIN_MODEL": "replace-with-your-small-model",
    "ACTOVIQ_DEFAULT_MEDIUM_MODEL": "replace-with-your-balanced-model",
    "ACTOVIQ_DEFAULT_MAX_MODEL": "replace-with-your-large-model"
  },
  "permissions": {
    "allow": [
      "Bash",
      "Write",
      "Read",
      "WebSearch",
      "WebFetch",
      "Edit",
      "Glop",
      "Grep",
      "LSP",
      "PowerShell"
    ]
  }
}
